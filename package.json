{
  "name": "my-world",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "shell": "nx serve shell --configuration development --port 4200 -o",
    "portfolio": "nx serve portfolio --configuration development --port 4201 -o",
    "blog": "nx serve blog --configuration development --port 4202 -o",
    "start": "nx run-many --target=serve --projects=shell,portfolio,blog --parallel=3",
    "build": "nx run-many --target=build --projects=shell,portfolio,blog --parallel=3",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "lint": "nx lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "^20.3.1",
    "@angular/animations": "^20.3.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.18",
    "@softarc/native-federation-node": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "es-module-shims": "^1.5.12",
    "express": "^5.1.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.18",
    "@angular-devkit/core": "^20.3.18",
    "@angular-devkit/schematics": "^20.3.18",
    "@angular/build": "^20.3.18",
    "@angular/cli": "^20.3.18",
    "@angular/compiler-cli": "^20.3.0",
    "@nx/angular": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@schematics/angular": "^20.3.18",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.0.1",
    "eslint": "^9.39.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.3.0",
    "nx": "22.5.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4"
  }
}
